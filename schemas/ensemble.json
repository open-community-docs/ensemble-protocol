{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ensemble-protocol.dev/schemas/ensemble.json",
  "title": "ESPEnsemble",
  "type": "object",
  "required": [
    "esp_version",
    "ensemble_id",
    "state",
    "coordinator",
    "members",
    "created_at"
  ],
  "properties": {
    "esp_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "ensemble_id": {
      "type": "string",
      "pattern": "^ens://[^/]+/[^/]+$"
    },
    "state": {
      "type": "string",
      "enum": ["proposed", "active", "suspended", "closing", "closed"]
    },
    "coordinator": { "type": "string", "minLength": 1 },
    "members": {
      "type": "array",
      "items": { "$ref": "member.json" },
      "minItems": 1
    },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}